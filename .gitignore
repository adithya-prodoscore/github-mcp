cat << 'EOF' > .gitignore
# Next.js Frontend Exclusions
node_modules/
.next/
out/
build/
.env.local
.env.development.local
.env.production.local

# FastAPI Python Backend Exclusions
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
.uv/
.pytest_cache/
.env

# System / IDE Exclusions
.DS_Store
.vscode/
.idea/
EOF